{
  "multipart": [
    { "apply": { "model": "mindcraftmod:block/rusted_iron_bars_post" } },
    {
      "when": { "north": "true" },
      "apply": { "model": "mindcraftmod:block/rusted_iron_bars_side",     "uvlock": true }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "mindcraftmod:block/rusted_iron_bars_side",     "y": 90, "uvlock": true }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "mindcraftmod:block/rusted_iron_bars_side_alt", "uvlock": true }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "mindcraftmod:block/rusted_iron_bars_side_alt", "y": 90, "uvlock": true }
    }
  ]
}
